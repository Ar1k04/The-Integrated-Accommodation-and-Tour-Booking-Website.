# ==========================================
# INFRASTRUCTURE & DATABASE
# ==========================================
POSTGRES_USER=travel_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=travel_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://travel_user:change_me@postgres:5432/travel_db

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
# Fail bookings with 503 when Redis is down (prevents overbooking external
# inventory). Keep true in prod; set false for local dev without Redis.
REDIS_LOCK_STRICT=true

# pgAdmin
PGADMIN_PORT=5050

# ==========================================
# BACKEND / APP
# ==========================================
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# GOOGLE OAUTH (Login with Google)
# ==========================================
# OAuth 2.0 Web client ID from Google Cloud Console. The frontend uses the
# same value as VITE_GOOGLE_CLIENT_ID; the backend verifies ID tokens against it.
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com

# ==========================================
# STRIPE
# ==========================================
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ==========================================
# CLOUDINARY
# ==========================================
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# ==========================================
# SMTP / EMAIL (Gmail)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace_me@example.com
SMTP_PASSWORD=replace_me
FROM_EMAIL=replace_me@example.com

# ==========================================
# DUFFEL (Flights)
# ==========================================
DUFFEL_TOKEN=duffel_test_replace_me

# ==========================================
# LITEAPI (Hotels)
# ==========================================
LITEAPI_KEY=replace_me

# ==========================================
# VIATOR (Tours)
# ==========================================
VIATOR_KEY=replace_me

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL=http://localhost:5173
