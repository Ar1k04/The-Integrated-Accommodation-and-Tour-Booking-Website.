@startuml System_Architecture_Booking_Website
title System Architecture вЂ” Integrated Accommodation, Flight & Tour Booking Website

skinparam {
    BackgroundColor #FAFAFA
    ArrowColor #2C3E50
    ArrowFontSize 11
    ArrowFontColor #2C3E50

    RectangleBackgroundColor #FDFEFE
    RectangleBorderColor #ABB2B9
    RectangleFontColor #1A252F
    RectangleFontStyle bold

    PackageBackgroundColor #FDFEFE
    PackageBorderColor #ABB2B9
    PackageFontColor #1A252F
    PackageFontStyle bold

    DefaultFontName Arial
    DefaultFontSize 12
    Shadowing false
    RoundCorner 6
}
package "User Interface" #EAF2FF {

    actor Customer as C #LightSkyBlue
    actor Partner  as P #LightSkyBlue
    actor Admin    as A #LightSkyBlue

    rectangle "Web Browser / Mobile Device" as Device #D6EAF8 {
        rectangle "Frontend Application\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nReact.js  |  HTML  |  CSS  |  JavaScript\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў UI Rendering & Routing\nвЂў Date Picker & Search Filters\nвЂў Booking Flow (Hotel, Flight, Tour)\nвЂў Payment Checkout (Stripe / VNPay)\nвЂў Admin Dashboard\nвЂў Partner Dashboard" as FE #EBF5FB
    }

    C --> Device : Collect Data /\nDisplay Results
    P --> Device : Collect Data /\nDisplay Results
    A --> Device : Collect Data /\nDisplay Results
}

package "Backend and App Logic" #EAF9EA {

    rectangle "API Web Server" as APIServer #C8E6C9 {
        rectangle "Backend API\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPython (FastAPI) / Pydantic / SQLAlchemy\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Authentication & JWT\nвЂў Business Logic\nвЂў Accommodation Module (via LiteAPI)\nвЂў Tour & Activities Module (via Viator)\nвЂў Flight Module (via Duffel)\nвЂў Booking & Concurrency Mgmt\nвЂў Review & Rating Module\nвЂў Voucher & Pricing Engine\nвЂў Loyalty Points Engine\nвЂў File Upload Handler (Cloudinary)\nвЂў Payment Routing (Stripe / VNPay)" as API #EAF9EA
    }

    rectangle "Payment Gateway" as PaymentServer #E8D5F5 {
        rectangle "Stripe\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Charge & Refund API\nвЂў Webhook Events\nвЂў Payment Intent\nвЂў Partner Payouts\nвЂў Test card: 4242 4242 4242 4242" as Stripe #F3E8FF

        rectangle "VNPay\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Domestic ATM / QR\nвЂў HMAC-SHA512 Checksum\nвЂў IPN Callback (URL public)\nвЂў vnp_TmnCode + HashSecret\nвЂў Sandbox: sandbox.vnpayment.vn" as VNPay #EDE7F6
    }

    rectangle "Cache Server" as CacheServer #FFF9C4 {
        rectangle "Redis\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Session Management\nвЂў Soft-Lock (TTL 15 min)\n  Room / Tour / Flight Inventory\nвЂў Prevent Double-Booking" as Redis #FFFDE7
    }

    rectangle "File Storage" as FileServer #FCE4EC {
        rectangle "Cloudinary (Cloud Image Storage)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Hotel Room Images\nвЂў Tour Gallery Photos\nвЂў User Avatars\nвЂў Document Attachments" as Storage #FFF0F3
    }
}

package "Agent Services (External API Providers)" #F5F5F5 {

    rectangle "Hotel Agent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLiteAPI (liteapi.travel)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў GET /data/hotels вЂ” Search hotels\nвЂў GET /data/hotel  вЂ” Hotel details\nвЂў GET /data/rooms  вЂ” Room types & images\nвЂў GET /data/reviews вЂ” Reviews + AI sentiment\nвЂў POST /hotels/rates вЂ” Realtime pricing\nвЂў POST /hotels/prebook вЂ” Confirm price\nвЂў POST /hotels/book вЂ” Create booking\nвЂў Loyalty & Voucher API\nвЂў Sandbox: free, no credit card" as HotelAgent #E3F2FD

    rectangle "Flight Agent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDuffel API (duffel.com)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Offer Request вЂ” Search flights\nвЂў Get Offers вЂ” Realtime pricing\nвЂў Create Order вЂ” Book flight\nвЂў Add Bags / Seats вЂ” Ancillaries\nвЂў Cancel Order + Refund\nвЂў 300+ airlines supported\nвЂў Sandbox: Duffel Airways (IATA: ZZ)\nвЂў Test token: duffel_test_..." as FlightAgent #E8F5E9

    rectangle "Tour & Activities Agent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nViator API (viator.com)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў POST /products/search вЂ” Search tours\nвЂў GET /products/{code} вЂ” Tour detail\nвЂў POST /availability/check вЂ” Realtime availability\nвЂў GET /availability/schedules вЂ” Date & pricing\nвЂў POST /search/freetext вЂ” Keyword search\nвЂў GET /destinations вЂ” Destination list\nвЂў 300,000+ products, 2,500+ destinations\nвЂў Sandbox: free affiliate key" as TourAgent #FFF8E1
}

package "Database" #FFF3E0 {

    rectangle "PostgreSQL вЂ” Primary Database\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў Users & Roles\nвЂў Accommodations & Rooms (cache from LiteAPI)\nвЂў Room Inventory\nвЂў Tour Listings (cache from Viator)\nвЂў Flight Bookings (from Duffel)\nвЂў Bookings & Reservations\nвЂў Payments & Transactions\nвЂў Reviews & Ratings\nвЂў Vouchers & Discounts\nвЂў Loyalty Tiers & Points\nвЂў Audit Logs\nвЂў Partner Profiles & Contracts" as PG #FFE0B2
}
FE  -->  API     : HTTP / REST API Requests & JSON Responses
API -->  FE      : HTTP / REST API Responses (JSON Data)

API <--> Stripe  : Payment Intent / Charge\nWebhook Confirmation
API <--> VNPay   : vnp_PaymentURL / IPN Callback\nHMAC Checksum Verify

API <--> Redis   : Cache Set / Get\nTTL Soft-Locks (15 min)

API <--> PG      : SQL Queries\n(Read & Write)

API <--> Storage : Store / Retrieve Media\n(Images & Files)

API <--> HotelAgent  : Hotel Search / Book\n(REST / JSON + API Key)
API <--> FlightAgent : Flight Search / Book\n(REST / JSON + Bearer Token)
API <--> TourAgent   : Tour Search / Availability\n(REST / JSON + API Key)

@enduml
