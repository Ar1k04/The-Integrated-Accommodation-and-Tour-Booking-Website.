@startuml Integrated_Accommodation_Tour_Booking_Website

' ─────────────────────────────────────────────
' Layout & Skin
' ─────────────────────────────────────────────
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 12
skinparam defaultFontName "Segoe UI"
skinparam linetype ortho

skinparam usecase {
  BackgroundColor      #EEF4FF
  BorderColor          #3B82F6
  FontSize             12
  FontColor            #1E3A5F
  ArrowColor           #4B5563
}

skinparam package {
  BackgroundColor      #F8FAFF
  BorderColor          #93C5FD
  FontStyle            bold
  FontColor            #1D4ED8
}

skinparam actor {
  BackgroundColor      #FFFFFF
  BorderColor          #6B7280
  FontStyle            bold
}

skinparam arrow {
  Color                #4B5563
  FontSize             11
  FontColor            #6B7280
}

' ─────────────────────────────────────────────
' Actors  (left side: Guest / Customer)
'          (right side: Partner / Admin)
' ─────────────────────────────────────────────
actor "Guest"    as Guest    #D1FAE5
actor "Customer" as Customer #DBEAFE

actor "Partner\n(Hotel Owner /\nTour Operator)" as Partner #FEF3C7
actor "Admin\n(Platform\nAdministrator)"         as Admin   #FEE2E2

' Generalization: Customer inherits Guest capabilities
Customer -u-|> Guest

' ─────────────────────────────────────────────
' System Boundary
' ─────────────────────────────────────────────
rectangle "Integrated Accommodation & Tour Booking Website" {

  ' ── Package 1 ────────────────────────────
  package "Search & Browse" as PKG_SEARCH {
    usecase "Search accommodations"   as UC_SEARCH_HOTEL
    usecase "Search tour, flight tickets"     as UC_SEARCH_TOUR
    usecase "Filter"        as UC_FILTER
    usecase "View details"            as UC_VIEW_DETAIL
    usecase "View reviews"            as UC_VIEW_REVIEW
  }

  ' ── Package 2 ────────────────────────────
  package "Authentication" as PKG_AUTH {
    usecase "Register"        as UC_REGISTER
    usecase "Login / Logout"  as UC_LOGIN
  }

  ' ── Package 3 ────────────────────────────
  package "Booking & Checkout" as PKG_BOOKING {
    usecase "Book room"            as UC_BOOK_ROOM
    usecase "Book tour, flight ticket"     as UC_BOOK_TOUR
    usecase "Select dates"         as UC_SELECT_DATES
    usecase "Add to cart"          as UC_ADD_CART
    usecase "View cart & checkout" as UC_CHECKOUT
    usecase "Make payment"         as UC_PAYMENT
    usecase "Cancel booking"       as UC_CANCEL
    usecase "View booking history" as UC_HISTORY
  }

  ' ── Package 4 ────────────────────────────
  package "Reviews & Loyalty" as PKG_LOYALTY {
    usecase "Write review & rating" as UC_REVIEW
    usecase "View points balance"   as UC_POINTS
    usecase "View tier benefits"    as UC_TIER
    usecase "Redeem loyalty points" as UC_REDEEM
  }

  ' ── Package 5 ────────────────────────────
  package "Vouchers" as PKG_VOUCHER {
    usecase "View available vouchers" as UC_VIEW_VOUCHER
    usecase "Apply voucher"           as UC_APPLY_VOUCHER
  }

  ' ── Package 6 ────────────────────────────
  package "Partner Dashboard" as PKG_PARTNER {
    usecase "Manage own room listings"        as UC_P_ROOMS
    usecase "Manage own tour, flight tickets"         as UC_P_TOURS
    usecase "Manage inventory & availability" as UC_P_INVENTORY
    usecase "Create Local Voucher"            as UC_P_VOUCHER
    usecase "Manage own bookings"             as UC_P_BOOKINGS
    usecase "View Partner reports"            as UC_P_REPORTS
  }

  ' ── Package 7 ────────────────────────────
  package "Admin Dashboard" as PKG_ADMIN {
    usecase "Approve / Reject Partners"     as UC_A_PARTNERS
    usecase "Manage system users"           as UC_A_USERS
    usecase "Manage loyalty tiers"          as UC_A_TIERS
    usecase "Create Global Voucher"         as UC_A_VOUCHER
    usecase "View Platform revenue dashboard" as UC_A_REPORTS
  }

}

' ─────────────────────────────────────────────
' Guest Associations
' ─────────────────────────────────────────────
Guest --> UC_SEARCH_HOTEL
Guest --> UC_SEARCH_TOUR
Guest --> UC_FILTER
Guest --> UC_VIEW_DETAIL
Guest --> UC_VIEW_REVIEW
Guest --> UC_REGISTER

' ─────────────────────────────────────────────
' Customer Associations (Customer-only use cases)
' ─────────────────────────────────────────────
Customer --> UC_LOGIN
Customer --> UC_BOOK_ROOM
Customer --> UC_BOOK_TOUR
Customer --> UC_CHECKOUT
Customer --> UC_CANCEL
Customer --> UC_HISTORY
Customer --> UC_REVIEW
Customer --> UC_POINTS
Customer --> UC_TIER
Customer --> UC_REDEEM
Customer --> UC_VIEW_VOUCHER

' ─────────────────────────────────────────────
' Partner Associations
' ─────────────────────────────────────────────
Partner --> UC_LOGIN
Partner --> UC_P_ROOMS
Partner --> UC_P_TOURS
Partner --> UC_P_INVENTORY
Partner --> UC_P_VOUCHER
Partner --> UC_P_BOOKINGS
Partner --> UC_P_REPORTS

' ─────────────────────────────────────────────
' Admin Associations
' ─────────────────────────────────────────────
Admin --> UC_LOGIN
Admin --> UC_A_PARTNERS
Admin --> UC_A_USERS
Admin --> UC_A_TIERS
Admin --> UC_A_VOUCHER
Admin --> UC_A_REPORTS

' ─────────────────────────────────────────────
' <<include>> Relationships (mandatory sub-steps)
' ─────────────────────────────────────────────
UC_BOOK_ROOM  ..> UC_SELECT_DATES : <<include>>
UC_BOOK_TOUR  ..> UC_SELECT_DATES : <<include>>
UC_BOOK_ROOM  ..> UC_ADD_CART     : <<include>>
UC_BOOK_TOUR  ..> UC_ADD_CART     : <<include>>
UC_CHECKOUT   ..> UC_PAYMENT      : <<include>>

' ─────────────────────────────────────────────
' <<extend>> Relationships (optional add-ons)
' Arrow: FROM extension TO base use case
' ─────────────────────────────────────────────
UC_APPLY_VOUCHER ..> UC_PAYMENT : <<extend>>
UC_REDEEM        ..> UC_PAYMENT : <<extend>>

@enduml
